{
  "name": "cdp-studio",
  "version": "0.1.0",
  "description": "CDP Studio — Node-based GUI for the Composers Desktop Project",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.20.0",
    "@xyflow/react": "^12.0.0",
    "electron-store": "^8.1.0",
    "wavesurfer.js": "^7.7.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.0",
    "electron-vite": "^2.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.cdpstudio.app",
    "productName": "CDP Studio",
    "mac": {
      "category": "public.app-category.music",
      "target": "dmg"
    },
    "files": ["out/**/*"],
    "extraResources": []
  }
}
